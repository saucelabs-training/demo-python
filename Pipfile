robotframework-pabot = "==5.2.2"
robotframework-seleniumlibrary = "==6.9.0"
apipkg = "==3.0.2"
attrs = "==26.1.0"
certifi = "==2026.5.20"
chardet = "==7.4.3"
decorator = "==5.3.1"
docutils = "==0.23"
execnet = "==2.1.2"
idna = "==3.18"
